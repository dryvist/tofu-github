use flake "github:dryvist/nix-devenv?dir=shells/terraform"

# Terrakube remote-backend coordinates for the empty `cloud {}` block in
# versions.tf: TF_CLOUD_HOSTNAME, TF_CLOUD_ORGANIZATION, TF_WORKSPACE. The API
# hostname is sensitive and the org login is an identity value, so all three
# live ONLY in the encrypted secrets/terrakube.sops.env (fleet age key at
# ~/.config/sops/age/keys.txt) — never plaintext in this public repo. Decrypt
# and export them at direnv load so `tofu init/plan/apply` reach the remote
# backend with no manual exports. Offline validation (tofu init -backend=false)
# needs none of this, so the block is guarded on sops + the file being present.
if has sops && [ -f secrets/terrakube.sops.env ]; then
  watch_file secrets/terrakube.sops.env
  eval "$(sops -d --input-type dotenv --output-type dotenv secrets/terrakube.sops.env | sed 's/^/export /')"
fi
