use flake "github:dryvist/nix-devenv?dir=shells/tofu"

# Terrakube remote-backend coordinates (TF_CLOUD_HOSTNAME, TF_CLOUD_ORGANIZATION,
# TF_WORKSPACE) for the empty `cloud {}` block in versions.tf. These are pulled
# via a central nix-devenv shell helper to keep this file generic and completely DRY.
# Offline validation (tofu init -backend=false && tofu validate) needs none of this,
# so the script fails gracefully when OpenBao is unreachable.
eval "$(export-terrakube-env)"
