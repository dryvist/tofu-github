use flake "github:dryvist/nix-devenv?dir=shells/terraform"

# Terrakube remote-backend coordinates (TF_CLOUD_HOSTNAME, TF_CLOUD_ORGANIZATION,
# TF_WORKSPACE) for the empty `cloud {}` block in versions.tf. These are a
# fleet-wide fact owned by the platform, so they live once in OpenBao
# (secret/platform/terrakube/main) — never duplicated as a per-repo secret in
# this public repo. Pull them at direnv load when the OpenBao AppRole is
# reachable; BAO_ADDR and the AppRole role_id/secret_id come from the operator's
# environment (Doppler / parent .envrc), so nothing sensitive — not even the
# internal endpoint — is committed here. Offline validation
# (tofu init -backend=false && tofu validate) needs none of this, so the block
# no-ops when BAO_ADDR or the AppRole creds are absent.
# ponytail: inline curl+jq; extract a shared bao-pull helper if a 3rd consumer appears.
if [ -n "${BAO_ADDR:-}" ] \
  && [ -n "${OPENBAO_APPROLE_TERRAFORM_ROLE_ID:-}" ] \
  && [ -n "${OPENBAO_APPROLE_TERRAFORM_SECRET_ID:-}" ]; then
  _bao_token="$(curl -sf --max-time 8 -X POST "${BAO_ADDR}/v1/auth/approle/login" \
    -d "{\"role_id\":\"${OPENBAO_APPROLE_TERRAFORM_ROLE_ID}\",\"secret_id\":\"${OPENBAO_APPROLE_TERRAFORM_SECRET_ID}\"}" \
    | jq -r '.auth.client_token // empty')"
  if [ -n "${_bao_token}" ]; then
    eval "$(curl -sf --max-time 8 -H "X-Vault-Token: ${_bao_token}" \
      "${BAO_ADDR}/v1/secret/data/platform/terrakube/main" \
      | jq -r '.data.data | to_entries[]
               | select(.key | test("^TF_CLOUD_|^TF_WORKSPACE$"))
               | "export \(.key)=\(.value | @sh)"')"
  fi
  unset _bao_token
fi
